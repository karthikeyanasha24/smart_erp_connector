# ============================================================
# SmarterP Connector Backend — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# Server
PORT=3000
NODE_ENV=development
TRUST_PROXY=1

# ── SQL Server (Primary ERP Database) ──────────────────────
# pyodbc = Windows + Microsoft ODBC | pymssql = Linux/Render + FreeTDS | auto = pick at runtime
MSSQL_DRIVER=auto
ODBC_DRIVER=ODBC Driver 18 for SQL Server
DB_SERVER=
DB_PORT=1433
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_CONNECT_TIMEOUT_MS=60000
DB_REQUEST_TIMEOUT_MS=480000
DB_POOL_MAX=20
DB_POOL_ACQUIRE_TIMEOUT_MS=180000

# ── PostgreSQL (RBAC & Connector Metadata) ─────────────────
DATABASE_URL=
RBAC_DATABASE_URL=
RBAC_ENABLED=1
RBAC_PERSIST=1

# ── AI / LLM ───────────────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── LangSmith Tracing ──────────────────────────────────────
LANGSMITH_API_KEY=
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_PROJECT=smarterpconnector
LANGSMITH_TRACING=true

# ── Authentication ─────────────────────────────────────────
JWT_SECRET=
ADMIN_DEFAULT_PASSWORD=
APP_LOGIN_EMAIL=
APP_LOGIN_PASSWORD=
APP_LOGIN_NAME=
APP_LOGIN_ROLE=admin

# ── Analytics Views (SQL Server) ───────────────────────────
ANALYTICS_BASE_TABLE=dbo.VW_MB_POWERBI_SLS_REPORT
SALES_VIEW=dbo.VwAISalesData
SALES_AI_TABLE=dbo.VW_MB_POWERBI_SLS_REPORT
BRANCH_VIEW=dbo.VwAIBranch
CUSTOMER_VIEW=dbo.VwAICustomerDetails
STOCK_VIEW=dbo.VwAIStockData
STOCK_TABLE=dbo.MstStockUnit
SALESPERSON_TABLE=dbo.MstSalesPerson
SALESPERSON_TOPN_VIEW=dbo.VW_MB_POWERBI_SLS_DATA_WITHOUT_ITEMID

# ── Analytics Column Mappings ──────────────────────────────
# VW_MB_POWERBI_SLS_REPORT columns:
SALES_ANALYTICS_AMOUNT_COLUMN=NetAmount
SALES_ANALYTICS_QUANTITY_COLUMN=NetSlsQty
SALES_ANALYTICS_BILL_COUNT_COLUMN=BillCount
SALES_ANALYTICS_BILL_COUNT_MODE=rows
SALES_ANALYTICS_BRANCH_DIM=BranchAlias
SALES_ANALYTICS_CATEGORY_DIM=CategoryShortName
SALES_ANALYTICS_DEPARTMENT_DIM=DepartmentShortName
MB_POWERBI_APP_REPORT_FILTER_DATE_COLUMN=XnMemoDate
MB_POWERBI_APP_REPORT_FILTER_BRANCH_COLUMN=BranchAlias
MB_POWERBI_APP_REPORT_FILTER_CATEGORY_COLUMN=CategoryShortName
MB_POWERBI_APP_REPORT_FILTER_DEPARTMENT_COLUMN=DepartmentShortName
# VwAISalesData columns:
SALES_FILTER_DATE_COLUMN=InvoiceDt
SALES_FILTER_BRANCH_COLUMN=BranchId
# VwAICustomerDetails columns:
CUSTOMERS_FILTER_DATE_COLUMN=CreatedOn
# VwAIStockData columns:
STOCK_FILTER_DATE_COLUMN=EntryDt
# VW_MB_POWERBI_SLS_DATA_WITHOUT_ITEMID columns:
SALESPERSON_DATE_COLUMN=CashmemoDt
SALESPERSON_AMOUNT_COLUMN=SalesNetAmount

# ── Analytics Behavior ─────────────────────────────────────
ANALYTICS_CACHE_TTL_MS=600000
ANALYTICS_STALE_TTL_MULTIPLIER=4
ANALYTICS_NOLOCK=1
ANALYTICS_RECOMPILE=1
ANALYTICS_RECOMPILE_THRESHOLD=30
ANALYTICS_TOP_N=30
ANALYTICS_TOP_N_MAX=200
ANALYTICS_SKIP_CUSTOMER_COUNT=0
ANALYTICS_WARMUP=1
ANALYTICS_WARMUP_INTERVAL_MS=900000
ANALYTICS_WARMUP_PAUSE_MS=3000
ANALYTICS_WARMUP_PERIODS=mtd,last_30d
HOME_KPI_REQUEST_TIMEOUT_MS=180000
DATASET_HARD_CAP=500000

# ── NLQ Intelligence ───────────────────────────────────────
NLQ_FAST_PATH=1
NLQ_INTENT_COMPILER=1
ADAPTIVE_INTENT_STEP=1
AI_ADAPTIVE_SUMMARY=1
AI_SCHEMA_DISABLE=0
AI_SCHEMA_MAX_TABLES=14
COGNITIVE_COLUMN_DISCOVERY=1
